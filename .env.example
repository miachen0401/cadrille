# Cadrille — environment variables.
#   1. Copy:    cp .env.example .env
#   2. Fill in your tokens below
#   3. Source:  set -a; source .env; set +a   (or rely on scripts/setup.sh)
#
# .env is gitignored. Never commit it.

# ─── HuggingFace ──────────────────────────────────────────────────────────────
# Required. Used for:
#   * downloading training data       (BenchCAD/cad_bench, Hula0401/cad-sft, …)
#   * downloading eval test meshes    (Hula0401/{deepCAD_test,fusion360_test_mesh})
#   * downloading the base model      (Qwen/Qwen2-VL-2B-Instruct)
# Get one at https://huggingface.co/settings/tokens.
#
# Scope: "read" is enough for training. Use "write" if you also want
# `hf_upload_repo` in your training config to push checkpoints during training.
HF_TOKEN=hf_...

# ─── Weights & Biases ─────────────────────────────────────────────────────────
# Required for training visualization (loss curves, online IoU, etc.).
# Get one at https://wandb.ai/authorize.
WANDB_API_KEY=...

# Optional. Set if you want runs to land in a specific org/team instead of your
# personal namespace. Otherwise wandb infers from the API key owner.
# WANDB_ENTITY=your-team

# ─── Optional: BenchCAD private dataset access ────────────────────────────────
# Only needed if you have a separate BenchCAD HF token (e.g. an org-scoped one).
# fetch_benchcad.py and fetch_cad_sft.py fall back to HF_TOKEN if this is empty.
# BenchCAD_HF_TOKEN=hf_...

# ─── Optional: GitHub PAT (dev-only) ──────────────────────────────────────────
# Only needed if you want to git push from this checkout via HTTPS without
# Git's interactive auth. Set to a fine-grained PAT with `contents: write`.
# GITHUB_PAT_TOKEN=ghp_...
