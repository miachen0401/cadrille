# Copy to .env and fill in your tokens, then: source .env
# Never commit .env — it is gitignored.

# HuggingFace — get token at https://huggingface.co/settings/tokens (read access is enough)
HF_TOKEN=hf_...

# Weights & Biases — get key at https://wandb.ai/authorize
WANDB_API_KEY=...

# Optional: set your W&B entity (team/username) to override the yaml default
# WANDB_ENTITY=your-username
